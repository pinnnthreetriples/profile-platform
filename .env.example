# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase public
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase private (server-only, never expose to browser)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# BTCPay Server (server-only, never expose to browser)
BTCPAY_SERVER_URL=https://your-btcpay-server.com
BTCPAY_API_KEY=your-btcpay-api-key
BTCPAY_STORE_ID=your-btcpay-store-id
BTCPAY_WEBHOOK_SECRET=your-btcpay-webhook-secret

# Payment config (public — MVP: USDT on TRON only)
NEXT_PUBLIC_PAYMENT_CURRENCY=USDT
NEXT_PUBLIC_PAYMENT_NETWORK=tron
