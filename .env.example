# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase public
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase private (server-only, never expose to browser)
SUPABASE_SERVICE_ROLE_KEY=

# BTCPay Server (server-only, never expose to browser)
# BTCPay Server URL, e.g. https://btcpay.example.com
BTCPAY_SERVER_URL=
# BTCPay Greenfield API key with store-level permissions
BTCPAY_API_KEY=
# BTCPay Store ID
BTCPAY_STORE_ID=
# BTCPay webhook secret (set in BTCPay store webhook settings)
BTCPAY_WEBHOOK_SECRET=

# Payment config (public — MVP: USDT on TRON only)
NEXT_PUBLIC_PAYMENT_CURRENCY=USDT
NEXT_PUBLIC_PAYMENT_NETWORK=tron
